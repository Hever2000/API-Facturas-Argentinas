# ZenithOCR Environment Configuration

# API
API_HOST=0.0.0.0
API_PORT=8000

# Groq (required for LLM extraction)
GROQ_API_KEY=your_groq_api_key_here

# PaddleOCR-VL (optional - remote API)
PADDLE_VL_API_URL=https://c6vceb62c4n8zfaf.aistudio-app.com/layout-parsing
PADDLE_VL_TOKEN=your_paddle_vl_token_here

# OCR Settings
OCR_PROVIDER=paddle_vl  # Options: paddle_vl, easyocr
OCR_LANGUAGES=en,es
OCR_GPU=false

# Logging
LOG_LEVEL=INFO
